---
import { getCollection, render } from "astro:content";
import { statSync } from "node:fs";

const raw = await getCollection("entries");

// Derive sensible fallbacks for files that lack frontmatter (arbitrary agent
// reports): title from the first H1 or the filename, date from a leading
// YYYY-MM-DD in the filename, status defaults to in-progress.
const prettifyId = (id: string) =>
  id
    .replace(/^\d{4}-\d{2}-\d{2}-?/, "")
    .replace(/[-_]/g, " ")
    .trim()
    .replace(/\b\w/g, (c) => c.toUpperCase()) || id;

const firstHeading = (body?: string) =>
  body?.match(/^#\s+(.+)$/m)?.[1]?.trim();

const dateFromId = (id: string) => {
  const m = id.match(/(\d{4})-(\d{2})-(\d{2})/);
  return m ? new Date(`${m[1]}-${m[2]}-${m[3]}`) : undefined;
};

const mtime = (entry: (typeof raw)[number]) => {
  try {
    return entry.filePath ? statSync(entry.filePath).mtime : undefined;
  } catch {
    return undefined;
  }
};

const entries = raw.map((entry) => {
  // Prefer explicit frontmatter, then a date in the filename, then the file's
  // own modified time — so even a bare dateless dump still orders sensibly.
  const date =
    entry.data.date ?? dateFromId(entry.id) ?? mtime(entry) ?? new Date(0);
  return {
    entry,
    title:
      entry.data.title ?? firstHeading(entry.body) ?? prettifyId(entry.id),
    author: entry.data.author,
    date,
    status: entry.data.status ?? "in-progress",
    tags: entry.data.tags,
  };
});

entries.sort((a, b) => b.date.valueOf() - a.date.valueOf());

// Pre-render each markdown body to a component.
const rendered = await Promise.all(
  entries.map(async (e) => ({
    ...e,
    Content: (await render(e.entry)).Content,
  })),
);

const statuses = ["all", "in-progress", "blocked", "done"];
const fmt = (d: Date) =>
  d.valueOf() === 0 ? "" : d.toISOString().slice(0, 10);
const built = new Date().toISOString().slice(0, 16).replace("T", " ");
// Group entries by date for Timeline view — insertion order preserves newest-first from rendered
const byDate: { date: string; items: (typeof rendered)[number][] }[] = [];
const _seenDates = new Map<string, number>();
for (const e of rendered) {
  const key = fmt(e.date) || "no date";
  if (!_seenDates.has(key)) {
    _seenDates.set(key, byDate.length);
    byDate.push({ date: key, items: [] });
  }
  byDate[_seenDates.get(key)!].items.push(e);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>agent-os · status dashboard</title>
  </head>
  <body>
    <header>
      <h1>🛰️ agent-os status</h1>
      <span class="sub">{entries.length} updates · built {built}</span>
      <div class="filters" id="filters">
        {
          statuses.map((s) => (
            <button data-status={s} class={s === "all" ? "active" : ""}>
              {s}
            </button>
          ))
        }
      </div>
    </header>

    <div class="columns">
      <section class="col col-branches">
        <details class="branches" id="branches" open>
          <summary>
            <span class="chevron">▸</span>
            <span class="branches-title">Active branches</span>
            <span class="branches-count" id="branches-count"></span>
            <span class="branches-live" id="branches-live" title="live">● live</span>
          </summary>
          <div class="branches-body" id="branches-body">
            <div class="branches-empty">Loading branch status…</div>
          </div>
        </details>
      </section>

      <div class="col col-feed">
        <div class="view-tabs" id="view-tabs">
          <button class="view-tab active" data-view="feed">Feed</button>
          <button class="view-tab" data-view="timeline">Timeline</button>
        </div>

        <div id="feed-view">
        {
          rendered.map(({ title, author, date, status, tags, Content }) => (
            <article class="card" data-status={status}>
              <div class="card-head">
                <h2>{title}</h2>
                <span class={`badge ${status}`}>{status}</span>
              </div>
              <div class="meta">
                {author}
                {fmt(date) && ` · ${fmt(date)}`}
                {tags.map((t) => (
                  <span class="tag"> #{t}</span>
                ))}
              </div>
              <div class="body-wrap">
                <div class="body">
                  <Content />
                </div>
                <button class="body-toggle" hidden>read more</button>
              </div>
            </article>
          ))
        }
        <div class="empty" id="empty" hidden>No entries for this status.</div>
        </div>

        <div id="timeline-view" hidden>
          <div class="tl-body">
          {byDate.map(({ date, items }) => (
            <div class="tl-group">
              <div class="tl-date-label">{date}</div>
              {items.map(({ title, author, date: d, status }) => (
                <div class="tl-row" data-status={status}>
                  <span class="tl-dot" aria-hidden="true"></span>
                  <div class="tl-info">
                    <span class="tl-title">{title}</span>
                    <span class="tl-meta">
                      {author || "unknown"}{fmt(d) && ` · ${fmt(d)}`}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          ))}
          </div>
          <div class="tl-empty" id="tl-empty" hidden>No entries for this status.</div>
        </div>
      </div>
    </div>

    <script>
      // --- Active branches panel: client-rendered from /branches.json so it can
      // poll and live-update without a full-page reload. ------------------------
      type PhaseItem = { id?: string; title: string; description?: string; status?: string };
      type TechContext = {
        language?: string;
        dependencies?: string;
        storage?: string;
        testing?: string;
        target_platform?: string;
        project_type?: string;
        performance?: string;
        constraints?: string;
        scale?: string;
      };
      type Complexity = { violation: string; why?: string; rejected?: string };
      type PhaseState = {
        status?: string;
        summary?: string;
        description?: string;
        items?: PhaseItem[];
        substeps?: Record<string, string>;
        // plan-phase extras (from SpecKit plan.md)
        tech_context?: TechContext;
        constitution?: "pass" | "violations" | "n/a";
        structure_decision?: string;
        complexity?: Complexity[];
      };
      type Branch = {
        id: string;
        branch: string;
        title: string;
        spec: string | null;
        issue: string | null;
        session: string | null;
        updated: string | null;
        phases: Record<string, PhaseState>;
        note: string | null;
      };

      const PHASES = ["specify", "plan", "tasks", "implement", "review"] as const;
      const REVIEW_STEPS = ["code", "comments", "tests", "errors", "types", "simplify", "pr"] as const;
      const GLYPH: Record<string, string> = {
        done: "✓",
        active: "●",
        blocked: "✕",
        pending: "○",
      };

      const esc = (s: string) =>
        s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c]!);

      const relTime = (iso: string | null) => {
        if (!iso) return "";
        const d = new Date(iso).getTime();
        if (Number.isNaN(d)) return "";
        const s = Math.round((Date.now() - d) / 1000);
        if (s < 60) return "just now";
        if (s < 3600) return `${Math.floor(s / 60)}m ago`;
        if (s < 86400) return `${Math.floor(s / 3600)}h ago`;
        return `${Math.floor(s / 86400)}d ago`;
      };

      const st = (p?: PhaseState) => p?.status ?? "pending";

      const cap = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);

      // "…/issues/42" -> "#42"; otherwise a generic "Issue" label.
      const issueLabel = (url: string) => {
        const n = url.match(/(\d+)\/?$/)?.[1];
        return n ? `#${n}` : "Issue";
      };

      const itemNoun: Record<string, string> = {
        specify: "User stories",
        plan: "Design items",
        tasks: "Tasks",
        implement: "Tasks",
        review: "Findings",
      };

      function pipeline(b: Branch) {
        return PHASES.map((name) => {
          const s = st(b.phases?.[name]);
          const sum = b.phases?.[name]?.summary;
          return `<li class="node ${s}" data-key="${b.id}::${name}" tabindex="0" role="button"
              aria-expanded="false" title="${esc(sum ?? "Show " + name + " details")}">
            <span class="dot">${GLYPH[s] ?? "○"}</span>
            <span class="node-name">${cap(name)}</span>
          </li>`;
        }).join("");
      }

      const TECH_FIELDS: [keyof TechContext, string][] = [
        ["language", "Language"],
        ["dependencies", "Dependencies"],
        ["storage", "Storage"],
        ["testing", "Testing"],
        ["target_platform", "Target platform"],
        ["project_type", "Project type"],
        ["performance", "Performance"],
        ["constraints", "Constraints"],
        ["scale", "Scale / scope"],
      ];

      // Extra plan.md-derived detail: Technical Context, Constitution verdict,
      // Structure Decision, Complexity Tracking.
      function planExtras(p?: PhaseState) {
        if (!p) return "";
        const tc = p.tech_context ?? {};
        const rows = TECH_FIELDS.filter(([k]) => tc[k])
          .map(
            ([k, label]) =>
              `<div class="tech-row"><dt>${label}</dt><dd>${esc(tc[k]!)}</dd></div>`,
          )
          .join("");
        const tech = rows
          ? `<div class="items-label">Technical context</div><dl class="tech-context">${rows}</dl>`
          : "";
        const constitution = p.constitution
          ? `<div class="constitution ${p.constitution}">Constitution: ${p.constitution === "n/a" ? "N/A" : cap(p.constitution)}</div>`
          : "";
        const structure = p.structure_decision
          ? `<div class="items-label">Structure decision</div><p class="phase-desc">${esc(p.structure_decision)}</p>`
          : "";
        const complexity = p.complexity?.filter((c) => c.violation).length
          ? `<div class="items-label">Complexity tracking</div>
             <ul class="complexity">${p.complexity
               .filter((c) => c.violation)
               .map(
                 (c) =>
                   `<li><span class="cx-violation">${esc(c.violation)}</span>${c.why ? `<span class="cx-line"><b>Why:</b> ${esc(c.why)}</span>` : ""}${c.rejected ? `<span class="cx-line"><b>Rejected:</b> ${esc(c.rejected)}</span>` : ""}</li>`,
               )
               .join("")}</ul>`
          : "";
        return constitution + tech + structure + complexity;
      }

      function phaseDetails(b: Branch) {
        return PHASES.map((name) => {
          const p = b.phases?.[name];
          const key = `${b.id}::${name}`;
          const extras = name === "plan" ? planExtras(p) : "";
          const desc = p?.description
            ? `<p class="phase-desc">${esc(p.description)}</p>`
            : "";
          const items = p?.items?.length
            ? `<div class="items-label">${itemNoun[name] ?? "Items"}</div>
               <ul class="items">${p.items
                 .map((it) => {
                   const s = it.status ?? "pending";
                   return `<li class="item ${s}">
                     <span class="item-dot">${GLYPH[s] ?? "○"}</span>
                     <span class="item-text"><span class="item-title">${it.id ? `<span class="item-id">${esc(it.id)}</span>` : ""}${esc(it.title)}</span>${it.description ? `<span class="item-desc">${esc(it.description)}</span>` : ""}</span>
                   </li>`;
                 })
                 .join("")}</ul>`
            : "";
          const inner =
            desc || items || extras
              ? desc + extras + items
              : `<p class="phase-empty">No ${(itemNoun[name] ?? "details").toLowerCase()} captured for ${cap(name)} yet.</p>`;
          return `<div class="phase-detail" data-key="${key}" hidden>
            <div class="phase-detail-head">
              <span class="phase-detail-name">${cap(name)}</span>
              ${p?.summary ? `<span class="phase-detail-sum">${esc(p.summary)}</span>` : ""}
            </div>
            ${inner}
          </div>`;
        }).join("");
      }

      const section = (title: string, inner: string) => `<details class="branch-section" open>
        <summary class="section-label"><span class="sec-chevron">▸</span>${title}</summary>
        <div class="section-body">${inner}</div>
      </details>`;

      function reviewSection(b: Branch) {
        const rv = b.phases?.review;
        if (!rv || st(rv) === "pending") return "";
        const subs = rv.substeps ?? {};
        const done = REVIEW_STEPS.filter((k) => (subs[k] ?? "pending") === "done").length;
        const chips = REVIEW_STEPS.map((k) => {
          const s = subs[k] ?? "pending";
          return `<li class="chip ${s}"><span class="chip-dot">${GLYPH[s] ?? "○"}</span>${k}</li>`;
        }).join("");
        return section(
          `Review passes <span class="section-count">${done}/${REVIEW_STEPS.length}</span>`,
          `<ul class="review-list">${chips}</ul>`,
        );
      }

      function activePhase(b: Branch) {
        const active = PHASES.find((n) => st(b.phases?.[n]) === "active");
        const blocked = PHASES.find((n) => st(b.phases?.[n]) === "blocked");
        if (blocked) return { label: blocked, cls: "blocked" };
        if (active) return { label: active, cls: "active" };
        const allDone = PHASES.every((n) => st(b.phases?.[n]) === "done");
        return allDone ? { label: "done", cls: "done" } : { label: "pending", cls: "pending" };
      }

      function card(b: Branch) {
        const cur = activePhase(b);
        const sum = b.phases?.[cur.label as string]?.summary;
        const collapsed = collapsedCards.has(b.id);
        return `<div class="branch-card ${cur.cls}${collapsed ? " collapsed" : ""}" data-branch="${b.id}">
          <div class="branch-head">
            <button class="card-toggle" type="button" aria-expanded="true" aria-label="Collapse ${esc(b.title)}">
              <span class="card-chevron">▸</span>
            </button>
            <div class="branch-heading">
              <h3 class="branch-title">${esc(b.title)}</h3>
              <div class="branch-sub">
                <code class="branch-name">${esc(b.branch)}</code>
                ${b.issue ? `<a class="issue-link" href="${esc(b.issue)}" target="_blank" rel="noopener">${esc(issueLabel(b.issue))} ↗</a>` : ""}
                ${b.session ? `<span class="session-name">⌥ ${esc(b.session)}</span>` : ""}
              </div>
            </div>
            <div class="branch-meta">
              <span class="branch-state ${cur.cls}">${cap(cur.label as string)}</span>
              <span class="branch-updated">${esc(relTime(b.updated))}</span>
            </div>
          </div>

          <div class="branch-card-body">
            ${section(
              "Pipeline",
              `<ol class="pipeline">${pipeline(b)}</ol>
               <div class="phase-details">${phaseDetails(b)}</div>`,
            )}

            ${reviewSection(b)}

            ${sum ? section("Latest", `<p class="branch-note">${esc(sum)}</p>`) : ""}
          </div>
        </details>`;
      }

      const bodyEl = document.getElementById("branches-body")!;
      const countEl = document.getElementById("branches-count")!;
      const liveEl = document.getElementById("branches-live")!;

      // Track which phase-detail panels are open (keyed branch::phase) so live
      // refreshes don't collapse what the user just opened.
      const openDetails = new Set<string>();

      // Cards default to expanded; remember any the user collapsed so a live
      // refresh doesn't pop them back open.
      const collapsedCards = new Set<string>();

      function applyOpen() {
        bodyEl.querySelectorAll<HTMLElement>(".node").forEach((n) => {
          const on = openDetails.has(n.dataset.key ?? "");
          n.classList.toggle("open", on);
          n.setAttribute("aria-expanded", on ? "true" : "false");
        });
        bodyEl.querySelectorAll<HTMLElement>(".phase-detail").forEach((d) => {
          d.hidden = !openDetails.has(d.dataset.key ?? "");
        });
        bodyEl
          .querySelectorAll<HTMLElement>(".branch-card")
          .forEach((card) => {
            const collapsed = collapsedCards.has(card.dataset.branch ?? "");
            card.classList.toggle("collapsed", collapsed);
            card
              .querySelector(".card-toggle")
              ?.setAttribute("aria-expanded", collapsed ? "false" : "true");
          });
      }

      function toggleCard(id: string) {
        if (collapsedCards.has(id)) collapsedCards.delete(id);
        else collapsedCards.add(id);
        applyOpen();
      }

      function toggleDetail(key: string) {
        if (openDetails.has(key)) openDetails.delete(key);
        else openDetails.add(key);
        applyOpen();
      }

      bodyEl.addEventListener("click", (e) => {
        // Links (e.g. the issue link) live inside the card <summary>; open them
        // without letting the click collapse/expand the card.
        const link = (e.target as HTMLElement).closest<HTMLAnchorElement>("a");
        if (link) {
          e.preventDefault();
          window.open(link.href, "_blank", "noopener");
          return;
        }
        // Only the chevron button collapses the card — the title stays selectable.
        const toggle = (e.target as HTMLElement).closest<HTMLElement>(".card-toggle");
        if (toggle) {
          const id = toggle.closest<HTMLElement>(".branch-card")?.dataset.branch;
          if (id) toggleCard(id);
          return;
        }
        const node = (e.target as HTMLElement).closest<HTMLElement>(".node");
        if (node?.dataset.key) toggleDetail(node.dataset.key);
      });
      bodyEl.addEventListener("keydown", (e) => {
        if (e.key !== "Enter" && e.key !== " ") return;
        const node = (e.target as HTMLElement).closest<HTMLElement>(".node");
        if (node?.dataset.key) {
          e.preventDefault();
          toggleDetail(node.dataset.key);
        }
      });

      async function refreshBranches() {
        try {
          const res = await fetch("/branches.json", { cache: "no-store" });
          if (!res.ok) throw new Error(String(res.status));
          const data: Branch[] = await res.json();
          countEl.textContent = data.length ? `${data.length}` : "";
          bodyEl.innerHTML = data.length
            ? data.map(card).join("")
            : `<div class="branches-empty">No active branches. Drop a file in <code>branches/</code>.</div>`;
          applyOpen();
          liveEl.classList.remove("stale");
          liveEl.animate?.([{ opacity: 0.35 }, { opacity: 1 }], { duration: 400 });
        } catch {
          liveEl.classList.add("stale");
        }
      }

      refreshBranches();
      setInterval(refreshBranches, 5000);

      // View tab switching with 120ms→150ms crossfade
      const viewTabs = document.getElementById("view-tabs")!;
      const feedView = document.getElementById("feed-view")!;
      const timelineView = document.getElementById("timeline-view")!;

      viewTabs.addEventListener("click", (e) => {
        const tab = (e.target as HTMLElement).closest<HTMLButtonElement>(".view-tab");
        if (!tab || tab.classList.contains("active")) return;
        const view = tab.dataset.view;
        viewTabs.querySelectorAll(".view-tab").forEach((t) =>
          t.classList.toggle("active", t === tab),
        );
        const outgoing = view === "timeline" ? feedView : timelineView;
        const incoming = view === "timeline" ? timelineView : feedView;
        outgoing.style.opacity = "0";
        outgoing.style.transition = "opacity 0.12s ease";
        setTimeout(() => {
          outgoing.hidden = true;
          outgoing.style.cssText = "";
          incoming.hidden = false;
          incoming.style.opacity = "0";
          requestAnimationFrame(() =>
            requestAnimationFrame(() => {
              incoming.style.opacity = "1";
              incoming.style.transition = "opacity 0.15s ease";
              incoming.addEventListener(
                "transitionend",
                () => { incoming.style.cssText = ""; },
                { once: true },
              );
            }),
          );
        }, 120);
      });

      // Feed card body truncation: animated expand / collapse
      document.querySelectorAll<HTMLElement>(".body-wrap").forEach((wrap) => {
        const body = wrap.querySelector<HTMLElement>(".body");
        const toggle = wrap.querySelector<HTMLElement>(".body-toggle");
        if (!body || !toggle) return;
        body.style.maxHeight = "9rem";
        if (body.scrollHeight > body.clientHeight + 4) {
          wrap.classList.add("truncated");
          toggle.hidden = false;
          toggle.addEventListener("click", () => {
            if (!wrap.classList.contains("expanded")) {
              const fullH = body.scrollHeight;
              body.style.maxHeight = fullH + "px";
              wrap.classList.add("expanded");
              wrap.classList.remove("truncated");
              toggle.textContent = "show less";
              body.addEventListener(
                "transitionend",
                () => {
                  body.style.maxHeight = "none";
                  body.style.overflow = "visible";
                },
                { once: true },
              );
            } else {
              body.style.overflow = "hidden";
              body.style.maxHeight = body.scrollHeight + "px";
              setTimeout(() => {
                body.style.maxHeight = "9rem";
                wrap.classList.remove("expanded");
                wrap.classList.add("truncated");
                toggle.textContent = "read more";
              }, 16);
            }
          });
        } else {
          body.style.maxHeight = "none";
          body.style.overflow = "visible";
        }
      });

      // Status filter: applies to both feed cards and timeline rows
      const filters = document.getElementById("filters")!;
      const cards = [...document.querySelectorAll<HTMLElement>(".card")];
      const empty = document.getElementById("empty")!;
      const tlRows = [...document.querySelectorAll<HTMLElement>(".tl-row")];
      const tlGroups = [...document.querySelectorAll<HTMLElement>(".tl-group")];
      const tlEmpty = document.getElementById("tl-empty")!;

      filters.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest("button");
        if (!btn || !btn.dataset.status) return;
        const status = btn.dataset.status;
        filters.querySelectorAll("button").forEach((b) =>
          b.classList.toggle("active", b === btn),
        );
        let visible = 0;
        for (const card of cards) {
          const show = status === "all" || card.dataset.status === status;
          card.hidden = !show;
          if (show) visible++;
        }
        empty.hidden = visible > 0;
        let tlVisible = 0;
        for (const row of tlRows) {
          const show = status === "all" || row.dataset.status === status;
          row.hidden = !show;
          if (show) tlVisible++;
        }
        tlEmpty.hidden = tlVisible > 0;
        for (const group of tlGroups) {
          const hasVisible = [...group.querySelectorAll<HTMLElement>(".tl-row")].some(
            (r) => !r.hidden,
          );
          group.hidden = !hasVisible;
        }
      });
    </script>

    <style is:global>
      :root {
        --bg: oklch(0.09 0.013 268);
        --panel: oklch(0.13 0.013 268);
        --border: oklch(0.24 0.018 268);
        --text: oklch(0.95 0.005 268);
        --muted: oklch(0.62 0.012 268);
        --accent: oklch(0.71 0.20 295);
        --done: oklch(0.72 0.17 145);
        --progress: oklch(0.76 0.13 75);
        --blocked: oklch(0.65 0.22 25);
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font:
          15px/1.6 -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
      }
      body > header {
        padding: 28px 24px 20px;
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 12px;
        position: sticky;
        top: 0;
        background: color-mix(in oklch, var(--bg) 85%, transparent);
        backdrop-filter: blur(8px);
        z-index: 5;
      }
      body > header h1 {
        margin: 0;
        font-size: 20px;
        letter-spacing: 0.3px;
      }
      body > header .sub {
        color: var(--muted);
        font-size: 13px;
      }
      .filters {
        margin-left: auto;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .filters button {
        background: var(--panel);
        color: var(--muted);
        border: 1px solid var(--border);
        padding: 5px 12px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 13px;
        transition: border-color 0.15s ease, color 0.15s ease;
      }
      .filters button.active {
        color: var(--text);
        border-color: var(--accent);
      }
      /* Two-column layout: Active branches (wide) + Updates feed (rail). */
      .columns {
        max-width: none;
        margin: 0;
        padding: 28px 32px 80px;
        display: grid;
        grid-template-columns: minmax(0, 40fr) minmax(0, 60fr);
        gap: 32px;
        align-items: start;
      }
      .col-feed {
        display: flex;
        flex-direction: column;
      }
      @media (max-width: 900px) {
        .columns {
          grid-template-columns: 1fr;
        }
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 18px 20px;
        margin-bottom: 16px;
        --card-surface: var(--panel);
      }
      .card[data-status="done"] {
        background: color-mix(in oklch, var(--done) 5%, var(--panel));
        --card-surface: color-mix(in oklch, var(--done) 5%, var(--panel));
      }
      .card[data-status="in-progress"] {
        background: color-mix(in oklch, var(--progress) 5%, var(--panel));
        --card-surface: color-mix(in oklch, var(--progress) 5%, var(--panel));
      }
      .card[data-status="blocked"] {
        background: color-mix(in oklch, var(--blocked) 5%, var(--panel));
        --card-surface: color-mix(in oklch, var(--blocked) 5%, var(--panel));
      }
      .card-head {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
      }
      .card-head h2 {
        margin: 0;
        font-size: 17px;
        flex: 1 1 auto;
      }
      .badge {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 3px 9px;
        border-radius: 20px;
        font-weight: 600;
      }
      .badge.done {
        background: color-mix(in oklch, var(--done) 15%, transparent);
        color: var(--done);
      }
      .badge.in-progress {
        background: color-mix(in oklch, var(--progress) 15%, transparent);
        color: var(--progress);
      }
      .badge.blocked {
        background: color-mix(in oklch, var(--blocked) 15%, transparent);
        color: var(--blocked);
      }
      .meta {
        color: var(--muted);
        font-size: 13px;
        margin-bottom: 12px;
      }
      .meta .tag {
        color: var(--accent);
      }
      .body {
        border-top: 1px solid var(--border);
        padding-top: 12px;
        overflow: hidden;
        transition: max-height 0.3s var(--ease-out-quart);
      }
      .body :first-child {
        margin-top: 0;
      }
      .body :last-child {
        margin-bottom: 0;
      }
      .body h1 {
        font-size: 1.1em;
        font-weight: 700;
        margin: 0.6em 0 0.4em;
        text-wrap: balance;
      }
      .body h2 {
        font-size: 1em;
        font-weight: 700;
        margin: 0.6em 0 0.4em;
      }
      .body h3,
      .body h4 {
        font-size: 0.95em;
        font-weight: 600;
        margin: 0.5em 0 0.3em;
      }
      .body code {
        background: color-mix(in oklch, var(--border) 60%, transparent);
        padding: 1px 5px;
        border-radius: 5px;
        font-size: 90%;
      }
      .body pre {
        background: oklch(0.04 0.006 268);
        padding: 12px;
        border-radius: 8px;
        overflow: auto;
      }
      .body pre code {
        background: none;
        padding: 0;
      }
      .body a {
        color: var(--accent);
      }
      .body p {
        max-width: 68ch;
        text-wrap: pretty;
      }
      .empty {
        color: var(--muted);
        text-align: center;
        padding: 60px 0;
      }

      /* View tabs (Feed / Timeline toggle) */
      .view-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
      }
      .view-tab {
        background: var(--panel);
        color: var(--muted);
        border: 1px solid var(--border);
        padding: 5px 16px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        transition: border-color 0.15s ease, color 0.15s ease;
      }
      .view-tab.active {
        color: var(--text);
        border-color: var(--accent);
      }

      /* Feed card body truncation */
      .body-wrap {
        position: relative;
      }
      .body-wrap::after {
        content: '';
        position: absolute;
        bottom: 26px;
        left: 0;
        right: 0;
        height: 3rem;
        background: linear-gradient(to bottom, transparent, var(--card-surface, var(--panel)));
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s ease;
      }
      .body-wrap.truncated::after {
        opacity: 1;
      }
      .body-toggle {
        background: none;
        border: none;
        color: var(--accent);
        font-size: 12px;
        font-weight: 600;
        padding: 6px 0 0;
        cursor: pointer;
        display: block;
        transition: opacity 0.1s ease;
      }
      .body-toggle[hidden] {
        display: none;
      }
      .body-toggle:hover {
        opacity: 0.75;
      }

      /* Timeline view */
      .tl-body {
        position: relative;
        padding-left: 24px;
      }
      .tl-body::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 20px;
        bottom: 16px;
        width: 1px;
        background: var(--border);
      }
      .tl-group {
        margin-bottom: 8px;
      }
      .tl-date-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--muted);
        padding: 14px 0 6px;
      }
      .tl-group:first-child .tl-date-label {
        padding-top: 2px;
      }
      .tl-row {
        position: relative;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 5px 0;
      }
      .tl-dot {
        position: absolute;
        left: -20px;
        top: 8px;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--panel);
        border: 1.5px solid var(--border);
        z-index: 1;
        flex-shrink: 0;
      }
      .tl-row[data-status="done"] .tl-dot {
        background: var(--done);
        border-color: var(--done);
      }
      .tl-row[data-status="in-progress"] .tl-dot {
        background: var(--progress);
        border-color: var(--progress);
      }
      .tl-row[data-status="blocked"] .tl-dot {
        background: var(--blocked);
        border-color: var(--blocked);
      }
      .tl-info {
        flex: 1;
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .tl-title {
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
        line-height: 1.35;
      }
      .tl-meta {
        font-size: 12px;
        color: var(--muted);
      }
      .tl-empty {
        color: var(--muted);
        text-align: center;
        padding: 40px 0;
        font-size: 14px;
      }

      /* --- Active branches panel ------------------------------------------- */
      .branches {
        margin: 0;
        padding: 0;
      }
      /* Panel title — the top of the hierarchy: biggest, boldest. */
      .branches > summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 18px;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        user-select: none;
      }
      .branches[open] > summary {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        border-bottom-color: transparent;
      }
      .branches > summary::-webkit-details-marker {
        display: none;
      }
      .branches .chevron {
        color: var(--muted);
        font-size: 12px;
        transition: transform 0.15s ease;
      }
      .branches[open] .chevron {
        transform: rotate(90deg);
      }
      .branches-title {
        font-weight: 700;
        font-size: 16px;
        letter-spacing: 0.2px;
      }
      .branches-count {
        background: color-mix(in oklch, var(--accent) 15%, transparent);
        color: var(--accent);
        font-size: 12px;
        font-weight: 700;
        padding: 2px 9px;
        border-radius: 20px;
        min-width: 12px;
        text-align: center;
      }
      .branches-count:empty {
        display: none;
      }
      .branches-live {
        margin-left: auto;
        color: var(--done);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      .branches-live.stale {
        color: var(--muted);
      }
      .branches-body {
        padding: 16px;
        display: grid;
        gap: 16px;
        background: transparent;
        border: 1px solid var(--border);
        border-top: none;
        border-bottom-left-radius: 12px;
        border-bottom-right-radius: 12px;
      }
      .branches-empty {
        color: var(--muted);
        font-size: 13px;
        padding: 10px 4px;
      }

      /* Branch card ------------------------------------------------------ */
      .branch-card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 18px 20px;
      }
      .branch-card.active {
        background: color-mix(in oklch, var(--progress) 5%, var(--panel));
      }
      .branch-card.blocked {
        background: color-mix(in oklch, var(--blocked) 5%, var(--panel));
      }
      .branch-card.done {
        background: color-mix(in oklch, var(--done) 5%, var(--panel));
      }

      /* Card header — the title is plain selectable text; only the chevron
         button toggles the card. */
      .branch-head {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 18px;
      }
      .branch-card.collapsed .branch-head {
        margin-bottom: 0;
      }
      .card-toggle {
        flex: none;
        margin-top: 2px;
        display: grid;
        place-items: center;
        width: 24px;
        height: 24px;
        padding: 0;
        background: transparent;
        border: 1px solid transparent;
        border-radius: 6px;
        color: var(--muted);
        cursor: pointer;
        transition: background 0.12s ease, border-color 0.12s ease;
      }
      .card-toggle:hover {
        background: color-mix(in oklch, var(--accent) 12%, transparent);
        border-color: color-mix(in oklch, var(--accent) 40%, transparent);
        color: var(--accent);
      }
      .card-toggle:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
      }
      .card-chevron {
        font-size: 13px;
        line-height: 1;
        transition: transform 0.15s ease;
      }
      .branch-card:not(.collapsed) .card-chevron {
        transform: rotate(90deg);
      }
      .branch-card-body {
        display: none;
      }
      .branch-card:not(.collapsed) .branch-card-body {
        display: block;
      }
      .branch-heading {
        display: flex;
        flex-direction: column;
        gap: 8px;
        min-width: 0;
      }
      .branch-meta {
        margin-left: auto;
      }
      .branch-title {
        margin: 0;
        font-size: 20px;
        font-weight: 700;
        line-height: 1.2;
        color: var(--text);
        letter-spacing: -0.2px;
        text-wrap: balance;
      }
      .branch-sub {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
      }
      .branch-name {
        background: color-mix(in oklch, var(--border) 55%, transparent);
        color: var(--muted);
        padding: 2px 8px;
        border-radius: 6px;
        font-size: 12px;
      }
      .issue-link {
        font-size: 12px;
        font-weight: 600;
        color: var(--accent);
        text-decoration: none;
        opacity: 0.85;
      }
      .issue-link:hover {
        opacity: 1;
        text-decoration: underline;
      }
      .session-name {
        font-size: 12px;
        color: var(--muted);
        opacity: 0.75;
        white-space: nowrap;
      }
      .branch-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
        flex: none;
      }
      .branch-state {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        white-space: nowrap;
      }
      .branch-state.active {
        background: color-mix(in oklch, var(--progress) 15%, transparent);
        color: var(--progress);
      }
      .branch-state.blocked {
        background: color-mix(in oklch, var(--blocked) 15%, transparent);
        color: var(--blocked);
      }
      .branch-state.done {
        background: color-mix(in oklch, var(--done) 15%, transparent);
        color: var(--done);
      }
      .branch-state.pending {
        background: color-mix(in oklch, var(--muted) 15%, transparent);
        color: var(--muted);
      }
      .branch-updated {
        color: var(--muted);
        font-size: 12px;
        white-space: nowrap;
      }

      /* Sections within a card — third tier: labelled groups with space. */
      .branch-section + .branch-section {
        margin-top: 16px;
      }
      /* Section headline — title case, colored, and a click target. */
      .section-label {
        margin: 0;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.2px;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 7px;
        cursor: pointer;
        user-select: none;
        list-style: none;
      }
      .section-label::-webkit-details-marker {
        display: none;
      }
      .sec-chevron {
        font-size: 10px;
        color: var(--accent);
        transition: transform 0.15s ease;
      }
      .branch-section[open] .sec-chevron {
        transform: rotate(90deg);
      }
      .section-count {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }
      .section-body {
        margin-top: 8px;
      }

      /* Pipeline — list items: the smallest, lightest tier. */
      .pipeline {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 20px 26px;
      }
      .pipeline .node {
        position: relative;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 400;
        color: var(--muted);
        cursor: pointer;
        padding: 4px 8px;
        margin: -4px -8px;
        border-radius: 8px;
        outline: none;
      }
      .pipeline .node:hover {
        background: color-mix(in oklch, var(--text) 4%, transparent);
      }
      .pipeline .node.open,
      .pipeline .node:focus-visible {
        background: color-mix(in oklch, var(--accent) 12%, transparent);
      }
      .pipeline .node .dot {
        transition: transform 0.12s ease;
      }
      .pipeline .node.open .dot {
        transform: scale(1.12);
      }
      /* connector line between consecutive nodes */
      .pipeline .node:not(:last-child)::after {
        content: "";
        position: absolute;
        left: calc(100% + 5px);
        top: 11px;
        width: 16px;
        height: 1px;
        background: var(--border);
      }
      .pipeline .node .dot {
        width: 22px;
        height: 22px;
        display: grid;
        place-items: center;
        border-radius: 50%;
        border: 1.5px solid var(--border);
        font-size: 11px;
        line-height: 1;
        flex: none;
      }
      .pipeline .node.done {
        color: var(--text);
      }
      .pipeline .node.done .dot {
        border-color: var(--done);
        color: var(--done);
        background: color-mix(in oklch, var(--done) 12%, transparent);
      }
      .pipeline .node.active {
        color: var(--progress);
        font-weight: 600;
      }
      .pipeline .node.active .dot {
        border-color: var(--progress);
        color: var(--progress);
        background: color-mix(in oklch, var(--progress) 14%, transparent);
      }
      .pipeline .node.blocked {
        color: var(--blocked);
        font-weight: 600;
      }
      .pipeline .node.blocked .dot {
        border-color: var(--blocked);
        color: var(--blocked);
        background: color-mix(in oklch, var(--blocked) 12%, transparent);
      }

      /* Expanded per-phase detail — stories / tasks / description. */
      .phase-details:has(.phase-detail:not([hidden])) {
        margin-top: 14px;
      }
      .phase-detail {
        border: 1px solid color-mix(in oklch, var(--accent) 30%, var(--border));
        border-radius: 8px;
        padding: 12px 14px;
        margin-top: 10px;
        background: color-mix(in oklch, var(--accent) 5%, var(--panel));
      }
      .phase-detail-head {
        display: flex;
        align-items: baseline;
        gap: 10px;
        margin-bottom: 8px;
      }
      .phase-detail-name {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
      }
      .phase-detail-sum {
        font-size: 12px;
        color: var(--muted);
      }
      .phase-desc {
        margin: 0 0 10px;
        font-size: 13px;
        line-height: 1.5;
        color: var(--text);
      }
      .items-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.4px;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 6px;
      }
      .items {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 7px;
      }
      .item {
        display: flex;
        align-items: flex-start;
        gap: 9px;
        font-size: 13px;
        line-height: 1.4;
        color: var(--muted);
      }
      .item-dot {
        flex: none;
        width: 16px;
        text-align: center;
        font-size: 11px;
        margin-top: 1px;
      }
      .item.done {
        color: var(--text);
      }
      .item.done .item-dot {
        color: var(--done);
      }
      .item.active {
        color: var(--text);
      }
      .item.active .item-dot {
        color: var(--progress);
      }
      .item.blocked .item-dot {
        color: var(--blocked);
      }
      .item.done .item-title {
        text-decoration: line-through;
        text-decoration-color: color-mix(in oklch, var(--muted) 50%, transparent);
      }
      .item-text {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .item-id {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 11px;
        color: var(--accent);
        margin-right: 6px;
      }
      .item.done .item-id,
      .item.active .item-id {
        display: inline;
      }
      .item-desc {
        color: var(--muted);
        font-size: 12px;
      }
      .phase-empty {
        margin: 0;
        font-size: 13px;
        color: var(--muted);
        font-style: italic;
      }

      /* Plan extras: constitution verdict, technical context, complexity. */
      .constitution {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.3px;
        text-transform: uppercase;
        padding: 3px 9px;
        border-radius: 20px;
        margin-bottom: 12px;
        border: 1px solid var(--border);
        color: var(--muted);
      }
      .constitution.pass {
        color: var(--done);
        border-color: color-mix(in oklch, var(--done) 45%, transparent);
        background: color-mix(in oklch, var(--done) 10%, transparent);
      }
      .constitution.violations {
        color: var(--blocked);
        border-color: color-mix(in oklch, var(--blocked) 45%, transparent);
        background: color-mix(in oklch, var(--blocked) 10%, transparent);
      }
      .tech-context {
        margin: 0 0 12px;
        display: grid;
        gap: 6px;
      }
      .tech-row {
        display: grid;
        grid-template-columns: 130px 1fr;
        gap: 10px;
        font-size: 13px;
      }
      .tech-row dt {
        color: var(--muted);
        font-weight: 600;
      }
      .tech-row dd {
        margin: 0;
        color: var(--text);
      }
      .complexity {
        list-style: none;
        margin: 0 0 4px;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .complexity li {
        display: flex;
        flex-direction: column;
        gap: 3px;
        font-size: 13px;
        border-left: 2px solid color-mix(in oklch, var(--blocked) 50%, transparent);
        padding-left: 10px;
      }
      .cx-violation {
        font-weight: 600;
        color: var(--text);
      }
      .cx-line {
        color: var(--muted);
      }
      @media (max-width: 560px) {
        .tech-row {
          grid-template-columns: 1fr;
          gap: 1px;
        }
      }

      /* Review passes — list items, as chips. */
      .review-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        border: 1px solid var(--border);
        color: var(--muted);
      }
      .chip .chip-dot {
        font-size: 10px;
      }
      .chip.done {
        color: var(--done);
        border-color: color-mix(in oklch, var(--done) 40%, transparent);
        background: color-mix(in oklch, var(--done) 8%, transparent);
      }
      .chip.active {
        color: var(--progress);
        border-color: color-mix(in oklch, var(--progress) 45%, transparent);
        background: color-mix(in oklch, var(--progress) 10%, transparent);
        font-weight: 600;
      }
      .chip.blocked {
        color: var(--blocked);
        border-color: color-mix(in oklch, var(--blocked) 45%, transparent);
        background: color-mix(in oklch, var(--blocked) 8%, transparent);
